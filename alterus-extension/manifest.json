{
  "manifest_version": 3,
  "name": "Alterus \u2014 Your AI Digital Twin",
  "version": "1.0.0",
  "description": "Draft emails and chats in your voice. Works on Gmail, Outlook, Slack, and Teams.",
  "permissions": [
    "storage",
    "identity",
    "clipboardWrite",
    "identity.email"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://outlook.office.com/*",
    "https://outlook.live.com/*",
    "https://app.slack.com/*",
    "https://teams.microsoft.com/*",
    "https://*.onrender.com/*",
    "https://*.railway.app/*",
    "https://*.streamlit.app/*",
    "https://gmail.googleapis.com/*",
    "https://slack.com/*",
    "https://app.alterus.io/*",
    "https://outlook.cloud.microsoft/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*",
        "https://outlook.office.com/*",
        "https://outlook.live.com/*",
        "https://app.slack.com/*",
        "https://teams.microsoft.com/*",
        "https://outlook.cloud.microsoft/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "sidebar.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://app.alterus.io/*",
        "https://outlook.cloud.microsoft/*"
      ],
      "js": [
        "app_bridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Alterus"
  },
  "oauth2": {
    "client_id": "289231572725-dnhhjdom2bop6cldnn8i4jta91gmvfu2.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly",
      "https://www.googleapis.com/auth/gmail.compose"
    ]
  },
  "externally_connectable": {
    "matches": [
      "https://app.alterus.io/*"
    ]
  }
}