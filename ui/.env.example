# ── Copy this to .env and fill in your values ─────────────────────────────────
# On Railway: set these as Environment Variables in the dashboard
# Locally: rename this file to .env

# ── Your Identity ─────────────────────────────────────────────────────────────
USER_NAME=Your Full Name
USER_TITLE=Your Job Title
USER_COMPANY=Your Company
USER_LOCATION=Your City, State
USER_EMAIL=your@email.com

# ── Your Key Stakeholders (comma separated, no spaces after commas) ────────────
USER_STAKEHOLDERS=Person One,Person Two,Person Three,Person Four,Person Five

# ── Your Active Workstreams (comma separated) ─────────────────────────────────
USER_WORKSTREAMS=Project One,Project Two,Project Three

# ── Communication Style ───────────────────────────────────────────────────────
# Options: direct / balanced / diplomatic
USER_TONE=balanced

# ── AI (Required for cloud deployment) ────────────────────────────────────────
# Get your key at: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── LangSmith (Optional — for tracing and self-healing) ───────────────────────
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=alterus
